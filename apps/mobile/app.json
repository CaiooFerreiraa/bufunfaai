{
  "expo": {
    "name": "BufunfaAI",
    "slug": "bufunfaai",
    "scheme": "bufunfaai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#070A12",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "router": {}
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
