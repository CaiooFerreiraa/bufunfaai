{
  "expo": {
    "name": "BufunfaAI",
    "slug": "bufunfaai",
    "scheme": "bufunfaai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "br.com.caiof.bufunfaai",
      "adaptiveIcon": {
        "backgroundColor": "#070A12",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "ios": {
      "bundleIdentifier": "br.com.caiof.bufunfaai"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-notifications",
      "@clerk/expo",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5c6c742f-14ae-41cd-a458-43706685c611"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "caioferreira"
  }
}
