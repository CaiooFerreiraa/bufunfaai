{
  "expo": {
    "name": "BufunfaAI",
    "slug": "bufunfaai",
    "scheme": "bufunfaai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "router": {}
    }
  }
}
