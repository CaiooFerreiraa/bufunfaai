APP_NAME=finance-api
APP_ENV=development
APP_PORT=8080

HTTP_READ_TIMEOUT=15
HTTP_WRITE_TIMEOUT=15
HTTP_SHUTDOWN_TIMEOUT=10

DATABASE_URL=postgres://postgres:postgres@localhost:5432/finance_app?sslmode=disable
REDIS_URL=redis://localhost:6379

CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

JWT_ACCESS_SECRET=change_me
JWT_ACCESS_ISSUER=finance-api
JWT_ACCESS_AUDIENCE=finance-mobile
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

APP_ENCRYPTION_KEY=0123456789ABCDEF0123456789ABCDEF

LOG_LEVEL=debug

OPENFINANCE_BASE_URL=
OPENFINANCE_CLIENT_ID=
OPENFINANCE_CLIENT_SECRET=
OPENFINANCE_MTLS_CERT_PATH=
OPENFINANCE_MTLS_KEY_PATH=
OPENFINANCE_PROVIDER_MODE=mock
CRON_SECRET=
WORKER_BATCH_SIZE=25

OPENAI_API_KEY=

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=0.1.0
SENTRY_TRACES_SAMPLE_RATE=0

DD_ENV=development
DD_SERVICE=finance-api
DD_VERSION=0.1.0
DD_TRACE_ENABLED=false
DATADOG_API_KEY=

EXPORTS_STORAGE_BUCKET=
EXPORTS_STORAGE_BASE_URL=
